// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL") // uses connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // uses a direct connection
}

model Donor {
  id         String   @id @default(cuid())
  name       String
  age        Int
  bloodType  String
  address    String
  phone      String
  isResident   Boolean  @default(true)
  lastDonation String   @default("more_than_4") // less_than_4, more_than_4
  hasDiseases  Boolean  @default(false)
  diseasesList String?
  status       String   @default("pending") // pending, approved, rejected, no_answer (used for blood request flow)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  isSuper   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  id          String   @id @default("default")
  title       String   @default("بدواي تتبرع | شبكة بدواي للتبرع بالدم")
  description String   @default("شبكة قرية بدواي للتبرع بالدم، معاً نحدث فرقاً.")
  keywords    String   @default("تبرع بالدم, بدواي, بنك الدم, انقاذ حياة")
  ogImage     String?
}
